{
  "name": "zao",
  "version": "1.0.0",
  "main": "index.js",
  "private": true,
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "prebuild": "expo prebuild --platform android --clean",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:ci": "jest --ci --coverage"
  },
  "dependencies": {
    "expo": "~57.0.2",
    "@expo/vector-icons": "^15.0.2",
    "expo-status-bar": "~57.0.0",
    "expo-sqlite": "~15.1.0",
    "expo-secure-store": "~14.0.0",
    "expo-notifications": "~0.31.0",
    "expo-file-system": "~18.0.0",
    "pdf-lib": "^1.17.1",
    "xlsx": "^0.18.5",
    "expo-system-ui": "~4.0.0",
    "expo-clipboard": "~56.0.4",
    "expo-haptics": "~57.0.0",
    "expo-blur": "~57.0.0",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-safe-area-context": "~4.14.0",
    "zustand": "^5.0.1",
    "uuid": "^9.0.1",
    "react-native-get-random-values": "~1.11.0",
    "@react-native-async-storage/async-storage": "1.24.0",
    "react-native-url-polyfill": "^2.0.0",
    "expo-image-picker": "~16.0.0",
    "expo-media-library": "~57.0.1",
    "expo-document-picker": "~13.0.0",
    "expo-image-manipulator": "~13.0.0",
    "docx": "^9.0.2",
    "jszip": "^3.10.1",
    "pptxgenjs": "^3.12.0",
    "papaparse": "^5.4.1",
    "expo-video-thumbnails": "^56.0.3",
    "expo-intent-launcher": "~56.0.4",
    "@babel/parser": "^7.25.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "babel-preset-expo": "^57.0.2",
    "jest": "^29.7.0",
    "jest-expo": "~57.0.0",
    "react-test-renderer": "19.2.3"
  },
  "overrides": {
    "@react-native/jest-preset": "0.86.0"
  },
  "jest": {
    "preset": "jest-expo",
    "moduleNameMapper": {
      "^uuid$": "<rootDir>/node_modules/uuid/dist/index.js",
      "^expo-file-system/legacy$": "<rootDir>/__mocks__/expo-file-system-legacy.js"
    },
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/server/",
      "/android/",
      "/ios/"
    ],
    "collectCoverageFrom": [
      "src/services/**/*.js",
      "!src/services/**/__tests__/**"
    ]
  }
}
